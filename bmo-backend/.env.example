# Banco de dados (Railway fornece automaticamente)
DATABASE_URL="postgresql://user:password@host:5432/bmo"

# JWT
JWT_SECRET="sua-chave-secreta-aqui-troque-isso"
JWT_EXPIRES_IN="7d"

# Ollama (IA)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# App
PORT=3000
NODE_ENV=development

#GrokAPI
GROQ_API_KEY="Sua_chave_grok_api_aqui"

# Firebase (Chat em tempo real)
# Gere em: Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
# Cole o JSON inteiro como string (escape as aspas)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
FIREBASE_DATABASE_URL="https://seu-projeto-default-rtdb.firebaseio.com"
