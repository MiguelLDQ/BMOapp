generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  role      UserRole @default(USER)
  isBanned  Boolean  @default(false)
  banReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks       Task[]
  moodEntries MoodEntry[]
  chatMembers ChatMember[]
  messages    Message[]
  reports     Report[]     @relation("ReportedBy")
  reportedMessages Report[] @relation("ReportedUser")
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodEntry {
  id        String   @id @default(uuid())
  userId    String
  mood      Int
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id        String       @id @default(uuid())
  name      String?
  type      ChatRoomType @default(GROUP)
  createdAt DateTime     @default(now())

  members  ChatMember[]
  messages Message[]
}

model ChatMember {
  id       String   @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model Message {
  id          String   @id @default(uuid())
  roomId      String
  userId      String
  content     String
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  room    ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports Report[]
}

model Report {
  id           String       @id @default(uuid())
  messageId    String
  reportedById String
  reportedUserId String
  reason       String
  status       ReportStatus @default(PENDING)
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())

  message      Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reportedBy   User    @relation("ReportedBy", fields: [reportedById], references: [id])
  reportedUser User    @relation("ReportedUser", fields: [reportedUserId], references: [id])
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum ChatRoomType {
  PRIVATE
  GROUP
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}
model DailyTask {
  id        String   @id @default(uuid())
  title     String   @unique
  category  String?
  createdAt DateTime @default(now())
}
model EstrelasMensagem {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
}